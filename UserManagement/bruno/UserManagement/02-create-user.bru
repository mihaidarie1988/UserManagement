meta {
  name: Create User
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/UserManagement/users
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "id": 0,
    "name": "Charlie",
    "email": "charlie@example.com"
  }
}
